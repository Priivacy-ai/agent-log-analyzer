{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/robertdouglass/claude-log-analyzer/contracts/tooling-utilization.json",
  "title": "ToolingUtilization",
  "description": "Bounded, privacy-safe MCP and skill bloat metrics nested inside Ecosystem in the analyzer report. Every string value comes from a closed enumeration or the public allowlist. Free-form strings (raw names, paths, schema text) MUST NOT appear here.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mcp", "skill"],
  "properties": {
    "mcp": { "$ref": "#/$defs/MCPUtilization" },
    "skill": { "$ref": "#/$defs/SkillUtilization" }
  },
  "$defs": {
    "countBucket": {
      "type": "string",
      "enum": ["none", "1-3", "4-10", "11-25", "26-50", "51-100", "100+", "unknown"]
    },
    "tokenBucket": {
      "type": "string",
      "enum": ["none", "<1k", "1k-5k", "5k-15k", "15k-50k", "50k+", "unknown"]
    },
    "efficiencyBucket": {
      "type": "string",
      "enum": ["unused", "underutilized", "moderate", "well-utilized", "unknown"]
    },
    "warningBand": {
      "type": "string",
      "enum": ["normal", "watch", "high", "severe", "unknown"]
    },
    "inferenceSource": {
      "type": "string",
      "enum": ["header", "calls", "none"]
    },
    "allowlistId": {
      "type": "string",
      "description": "An ID from internal/analyzer/signatures/{mcp_servers,skills}.json. Lowercase with underscores. Never a raw user-provided name.",
      "pattern": "^[a-z0-9_]+$"
    },
    "MCPUtilization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "known_server_ids", "unknown_server_count",
        "server_count_bucket", "exposed_tool_count_bucket", "context_token_bucket",
        "exposure_known", "inference_source",
        "call_count", "known_call_count", "unknown_call_count",
        "unique_known_called_ids", "unique_unknown_called_count",
        "utilization_ratio_pct", "context_efficiency_bucket", "warning_band"
      ],
      "properties": {
        "known_server_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowlistId" },
          "uniqueItems": true
        },
        "unknown_server_count": { "type": "integer", "minimum": 0 },
        "server_count_bucket": { "$ref": "#/$defs/countBucket" },
        "exposed_tool_count_bucket": { "$ref": "#/$defs/countBucket" },
        "context_token_bucket": { "$ref": "#/$defs/tokenBucket" },
        "exposure_known": { "type": "boolean" },
        "inference_source": { "$ref": "#/$defs/inferenceSource" },
        "call_count": { "type": "integer", "minimum": 0 },
        "known_call_count": { "type": "integer", "minimum": 0 },
        "unknown_call_count": { "type": "integer", "minimum": 0 },
        "unique_known_called_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowlistId" },
          "uniqueItems": true
        },
        "unique_unknown_called_count": { "type": "integer", "minimum": 0 },
        "utilization_ratio_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "context_efficiency_bucket": { "$ref": "#/$defs/efficiencyBucket" },
        "warning_band": { "$ref": "#/$defs/warningBand" }
      }
    },
    "SkillUtilization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "known_exposed_ids", "unknown_exposed_count",
        "exposed_count_bucket", "context_token_bucket",
        "exposure_known", "inference_source",
        "executed_count", "known_executed_ids", "unknown_executed_count",
        "utilization_ratio_pct", "context_efficiency_bucket", "warning_band"
      ],
      "properties": {
        "known_exposed_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowlistId" },
          "uniqueItems": true
        },
        "unknown_exposed_count": { "type": "integer", "minimum": 0 },
        "exposed_count_bucket": { "$ref": "#/$defs/countBucket" },
        "context_token_bucket": { "$ref": "#/$defs/tokenBucket" },
        "exposure_known": { "type": "boolean" },
        "inference_source": { "$ref": "#/$defs/inferenceSource" },
        "executed_count": { "type": "integer", "minimum": 0 },
        "known_executed_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowlistId" },
          "uniqueItems": true
        },
        "unknown_executed_count": { "type": "integer", "minimum": 0 },
        "utilization_ratio_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "context_efficiency_bucket": { "$ref": "#/$defs/efficiencyBucket" },
        "warning_band": { "$ref": "#/$defs/warningBand" }
      }
    }
  },
  "x-invariants": [
    "exposure_known=false implies all *_bucket fields are 'unknown', utilization_ratio_pct=0, and warning_band='unknown'.",
    "warning_band='severe' implies the high-band conditions hold AND at least one of Metrics.Rereads>=3, Metrics.RetryDepthMax>=3, Metrics.ContextGrowthEvents>=2.",
    "Aggregate output (AggregateSafeEvent.Ecosystem.tooling_utilization) contains only enum values and integer counts. Free-form strings are never present."
  ]
}
